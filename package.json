{
  "name": "agentplat",
  "version": "0.2.0-beta.6",
  "private": true,
  "description": "Open-core runtime primitives for building agentic platforms.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "type-check": "pnpm -r --workspace-concurrency=4 run type-check && pnpm run type-check:public",
    "type-check:public": "tsc -p tsconfig.type-tests.json",
    "test:unit": "node --test tests/*.test.mjs",
    "test:adapters": "pnpm --filter @agentplat/rooms-api test && pnpm --filter @agentplat/rooms-postgres test",
    "test": "pnpm run build && pnpm run test:unit && pnpm run test:adapters",
    "example:basic": "pnpm run build && node examples/basic-runtime.mjs",
    "example:quick": "pnpm run build && node examples/quick-run.mjs",
    "example:sessions": "pnpm run build && node examples/multi-agent-session.mjs",
    "example:rooms": "pnpm --dir examples/rooms-api start",
    "audit:public": "node scripts/audit-public.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "verify:pack": "node scripts/pack-smoke.mjs",
    "version:set": "node scripts/set-version.mjs",
    "release:publish": "pnpm run check && node scripts/publish-packages.mjs",
    "release:publish:next": "NPM_DIST_TAG=next pnpm run release:publish",
    "check": "pnpm run audit:public && pnpm run build && pnpm run type-check && pnpm run test:unit && pnpm run test:adapters && pnpm run verify:release && pnpm run verify:pack"
  },
  "devDependencies": {
    "@agentplat/audit": "workspace:*",
    "@agentplat/auth": "workspace:*",
    "@agentplat/core": "workspace:*",
    "@agentplat/events": "workspace:*",
    "@agentplat/framework": "workspace:*",
    "@agentplat/mcp": "workspace:*",
    "@agentplat/memory": "workspace:*",
    "@agentplat/model": "workspace:*",
    "@agentplat/model-openai-compatible": "workspace:*",
    "@agentplat/provider-openai": "workspace:*",
    "@agentplat/rooms": "workspace:*",
    "@agentplat/rooms-api": "workspace:*",
    "@agentplat/rooms-postgres": "workspace:*",
    "@agentplat/runtime": "workspace:*",
    "@agentplat/runtime-mock": "workspace:*",
    "@agentplat/sessions": "workspace:*",
    "@agentplat/streaming": "workspace:*",
    "@agentplat/tools": "workspace:*",
    "@agentplat/workflows": "workspace:*",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  }
}
