{
  "name": "agentplat",
  "version": "0.1.0",
  "private": true,
  "description": "Open-core framework for building agentic platforms.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@8.10.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "corepack pnpm -r --if-present run build",
    "lint": "corepack pnpm -r --if-present run lint",
    "type-check": "corepack pnpm -r --workspace-concurrency=4 run type-check",
    "clean": "corepack pnpm -r --if-present run clean"
  },
  "devDependencies": {
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  }
}
