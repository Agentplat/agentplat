{
  "name": "@agentplat/a2a",
  "version": "0.2.0-beta.11",
  "description": "A2A v1 HTTP+JSON interoperability for AgentPlat.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
