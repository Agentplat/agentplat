  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agentplat/agentplat.git",
    "directory": "packages/a2a"
