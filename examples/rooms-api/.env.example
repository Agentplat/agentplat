# PostgreSQL used by the reference application.
POSTGRES_DB=agentplat
POSTGRES_USER=agentplat
POSTGRES_PASSWORD=agentplat
POSTGRES_PORT=5432

# API settings.
API_PORT=3000
PGHOST=localhost
PGPORT=5432
PGDATABASE=agentplat
PGUSER=agentplat
PGPASSWORD=agentplat

# DATABASE_URL is also supported. Prefer a secret manager rather than checking
# a credential-bearing URL into source control.
# DATABASE_URL=

# Used only by scripts/demo.sh. The API always reads the tenant from the
# X-Agentplat-Tenant-Id request header.
AGENTPLAT_TENANT_ID=acme
